---
// NeuralBackground.astro
// Renders an animated neural network canvas in the hero section.
// Falls back to a static CSS gradient if Canvas API is not supported.
---

<div class="neural-background">
  <canvas id="neural-canvas" class="neural-canvas"></canvas>
  <div class="neural-fallback"></div>
</div>

<style>
  .neural-background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .neural-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Static CSS gradient fallback — hidden by default when canvas works */
  .neural-fallback {
    display: none;
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 44%, rgba(6, 182, 212, 0.16), transparent 36%),
      radial-gradient(circle at 22% 28%, rgba(59, 130, 246, 0.1), transparent 28%),
      radial-gradient(circle at 82% 24%, rgba(139, 92, 246, 0.09), transparent 30%),
      radial-gradient(circle at 76% 76%, rgba(236, 72, 153, 0.06), transparent 32%),
      linear-gradient(135deg, rgba(6, 182, 212, 0.05), rgba(59, 130, 246, 0.04), rgba(139, 92, 246, 0.03));
  }

  /* Show fallback when canvas is hidden (no-canvas class added by script) */
  .neural-background.no-canvas .neural-canvas {
    display: none;
  }

  .neural-background.no-canvas .neural-fallback {
    display: block;
  }
</style>

<script>
  import { initNeuralNetwork } from '../scripts/neural-network';

  function setup() {
    const container = document.querySelector('.neural-background') as HTMLDivElement | null;
    const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement | null;

    if (!container || !canvas) return;

    // Check Canvas API support
    if (!canvas.getContext) {
      container.classList.add('no-canvas');
      return;
    }

    // Check prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      container.classList.add('no-canvas');
      return;
    }

    // Size canvas to parent
    canvas.width = container.clientWidth;
    canvas.height = container.clientHeight;

    const isDark = document.documentElement.dataset.theme === 'dark';

    const nn = initNeuralNetwork({
      canvas,
      nodeCount: 54,
      connectionDistance: 170,
      isDarkMode: isDark,
      colors: {
        cyan: '#06b6d4',
        blue: '#3b82f6',
        purple: '#8b5cf6',
        magenta: '#ec4899',
      },
    });

    nn.start();

    // Listen for theme changes via data-theme attribute on <html>
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
          const newIsDark = document.documentElement.dataset.theme === 'dark';
          nn.updateTheme(newIsDark);
        }
      }
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    // Listen for window resize
    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        nn.resize();
      }, 250);
    });

    // Cleanup on page navigation (Astro view transitions)
    document.addEventListener('astro:before-swap', () => {
      nn.stop();
      observer.disconnect();
    }, { once: true });
  }

  // Run on initial load
  setup();

  // Re-run after Astro view transitions
  document.addEventListener('astro:page-load', () => {
    setup();
  });
</script>
