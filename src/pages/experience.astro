---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { marked } from 'marked';

// 기본 언어는 한국어로 설정 (나중에 쿼리 파라미터로 변경 가능)
const lang = Astro.url.searchParams.get('lang') || 'ko';

const allExperiences = (await getCollection('experience'))
  .filter((exp: CollectionEntry<'experience'>) => exp.data.lang === lang)
  .sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => a.data.order - b.data.order);

// 마크다운 렌더링을 미리 처리
const workExperiences = await Promise.all(
  allExperiences
    .filter((exp: CollectionEntry<'experience'>) => exp.data.type === 'work')
    .map(async (exp: CollectionEntry<'experience'>) => ({
      ...exp,
      htmlContent: await marked.parse(exp.body)
    }))
);

const projects = await Promise.all(
  allExperiences
    .filter((exp: CollectionEntry<'experience'>) => exp.data.type === 'project')
    .map(async (exp: CollectionEntry<'experience'>) => ({
      ...exp,
      htmlContent: await marked.parse(exp.body)
    }))
);

const research = await Promise.all(
  allExperiences
    .filter((exp: CollectionEntry<'experience'>) => exp.data.type === 'research')
    .map(async (exp: CollectionEntry<'experience'>) => ({
      ...exp,
      htmlContent: await marked.parse(exp.body)
    }))
);

const title = lang === 'ko' ? '경력 & 프로젝트' : 'Experience & Projects';
const workTitle = lang === 'ko' ? '💼 업무 경력' : '💼 Work Experience';
const projectTitle = lang === 'ko' ? '🚀 프로젝트' : '🚀 Projects';
const researchTitle = lang === 'ko' ? '🔬 연구 경험' : '🔬 Research Experience';
---

<BaseLayout title={title} description={lang === 'ko' ? '민동익(Douglas)의 경력과 프로젝트' : 'Dongik Min\'s Experience and Projects'}>
  <div class="language-toggle">
    <a href="/experience?lang=ko" class:list={['lang-btn', { active: lang === 'ko' }]}>한국어</a>
    <a href="/experience?lang=en" class:list={['lang-btn', { active: lang === 'en' }]}>English</a>
  </div>

  <section class="page-header">
    <div class="container">
      <h1 class="animate-fade-in">{title}</h1>
      <p class="animate-fade-in">
        {lang === 'ko' ? '다양한 프로젝트와 경험을 통해 성장해왔습니다' : 'Growing through diverse projects and experiences'}
      </p>
    </div>
  </section>

  {workExperiences.length > 0 && (
    <section class="experience-section">
      <div class="container">
        <h2 class="section-title">{workTitle}</h2>
        <div class="timeline">
          {workExperiences.map((exp, index: number) => (
            <article class="timeline-item" style={`animation-delay: ${index * 0.1}s`}>
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="exp-header">
                  <div>
                    <h3>{exp.data.title}</h3>
                    <p class="company">{exp.data.company}</p>
                    {exp.data.role && <p class="role">{exp.data.role}</p>}
                  </div>
                  <span class="period">{exp.data.period}</span>
                </div>
                <div class="exp-body" set:html={exp.htmlContent} />
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {projects.length > 0 && (
    <section class="experience-section project-section">
      <div class="container">
        <h2 class="section-title">{projectTitle}</h2>
        <div class="timeline">
          {projects.map((exp, index: number) => (
            <article class="timeline-item" style={`animation-delay: ${index * 0.1}s`}>
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="exp-header">
                  <div>
                    <h3>{exp.data.title}</h3>
                    <p class="company">{exp.data.company}</p>
                    {exp.data.role && <p class="role">📌 {exp.data.role}</p>}
                  </div>
                  <span class="period">{exp.data.period}</span>
                </div>
                <div class="exp-body" set:html={exp.htmlContent} />
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {research.length > 0 && (
    <section class="experience-section research-section">
      <div class="container">
        <h2 class="section-title">{researchTitle}</h2>
        <div class="timeline">
          {research.map((exp, index: number) => (
            <article class="timeline-item" style={`animation-delay: ${index * 0.1}s`}>
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="exp-header">
                  <div>
                    <h3>{exp.data.title}</h3>
                    <p class="company">{exp.data.company}</p>
                    {exp.data.role && <p class="role">👨‍🔬 {exp.data.role}</p>}
                  </div>
                  <span class="period">{exp.data.period}</span>
                </div>
                <div class="exp-body" set:html={exp.htmlContent} />
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .language-toggle {
    position: fixed;
    top: 100px;
    right: 2rem;
    z-index: 100;
    display: flex;
    gap: 0.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 0.25rem;
    box-shadow: var(--shadow-md);
  }

  .lang-btn {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    transition: all var(--transition-fast);
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .lang-btn:hover {
    background: var(--color-bg);
    color: var(--color-accent);
  }

  .lang-btn.active {
    background: var(--color-accent);
    color: white;
  }

  .page-header {
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align: center;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: var(--spacing-md);
  }

  .page-header p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
  }

  .experience-section {
    padding: var(--spacing-2xl) 0;
  }

  .section-title {
    font-size: 2rem;
    margin-bottom: var(--spacing-xl);
    text-align: center;
    background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: repeating-linear-gradient(
      180deg,
      var(--color-ai-cyan) 0px,
      var(--color-ai-blue) 4px,
      transparent 4px,
      transparent 8px,
      var(--color-ai-purple) 8px,
      var(--color-ai-magenta) 12px,
      transparent 12px,
      transparent 16px
    );
    background-size: 2px 16px;
    animation: timeline-pulse 3s ease-in-out infinite;
  }

  @keyframes timeline-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .timeline-item {
    position: relative;
    margin-bottom: var(--spacing-xl);
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  .timeline-marker {
    position: absolute;
    left: -2.35rem;
    top: 0.5rem;
    width: 14px;
    height: 14px;
    border-radius: 0;
    background: linear-gradient(135deg, var(--color-ai-cyan), var(--color-ai-purple));
    border: 2px solid var(--color-bg);
    box-shadow: 0 0 8px rgba(6, 182, 212, 0.5), 0 0 16px rgba(139, 92, 246, 0.2);
    z-index: 1;
    transform: rotate(45deg);
    transition: box-shadow var(--transition-base);
  }

  .timeline-item:hover .timeline-marker {
    box-shadow: 0 0 14px rgba(6, 182, 212, 0.8), 0 0 28px rgba(139, 92, 246, 0.4), 0 0 40px rgba(6, 182, 212, 0.2);
  }

  .timeline-content {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    transition: all var(--transition-base);
  }

  .timeline-content:hover {
    transform: translateX(8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
  }

  .exp-header h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .company {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .role {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    font-style: italic;
  }

  .period {
    background: var(--color-bg);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    white-space: nowrap;
    border: 1px solid var(--color-border);
  }

  .exp-body {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .exp-body :global(h2) {
    font-size: 1.125rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .exp-body :global(ul) {
    list-style: none;
    padding-left: 0;
  }

  .exp-body :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .exp-body :global(li::before) {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .language-toggle {
      top: 80px;
      right: 1rem;
    }

    .timeline {
      padding-left: 1.5rem;
    }

    .timeline-marker {
      left: -1.85rem;
    }

    .exp-header {
      flex-direction: column;
    }

    .period {
      align-self: flex-start;
    }

    .timeline-content:hover {
      transform: translateX(4px);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
