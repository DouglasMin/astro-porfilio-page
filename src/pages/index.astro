---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeuralBackground from '../components/NeuralBackground.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allProjects = await getCollection('projects');

const featuredProjects = allProjects
  .filter(
    (project: CollectionEntry<'projects'>) =>
      project.data.featured && project.data.category !== 'client',
  )
  .sort(
    (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
      a.data.order - b.data.order,
  )
  .slice(0, 3);

const clientProjects = allProjects
  .filter((project: CollectionEntry<'projects'>) => project.data.category === 'client')
  .sort(
    (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
      a.data.order - b.data.order,
  )
  .slice(0, 2);
---

<BaseLayout title="민동익 (Douglas) - 개발자 포트폴리오" description="민동익(Douglas)의 풀스택 개발자 포트폴리오 웹사이트">
  <!-- Hero Section -->
  <section class="hero">
    <NeuralBackground />
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title hero-stagger" style="--stagger-index: 0">
          안녕하세요! 👋<br />
          저는 <span class="gradient-text">민동익</span> 입니다
        </h1>
        <p class="hero-description hero-stagger" style="--stagger-index: 1">
          사용자 경험을 최우선으로 생각하는 풀스택 개발자입니다.<br />
          사용자가 필요로 하는 애플리케이션을 빠르게 MVP로 만들어<br />
          시장 반응을 확인합니다.
        </p>
        <p class="hero-subtitle hero-stagger" style="--stagger-index: 2">
          Dongik Min (Douglas)
        </p>
        <div class="typewriter-wrapper hero-stagger" style="--stagger-index: 3">
          <span id="typewriter-text" class="typewriter-text" aria-live="polite"></span>
          <span class="typewriter-cursor" aria-hidden="true">|</span>
        </div>
        <div class="hero-cta hero-stagger" style="--stagger-index: 4">
          <a href="/projects" class="btn btn-primary">프로젝트 보기</a>
          <a href="/about" class="btn btn-secondary">소개 보기</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="skills-section">
    <div class="container">
      <h2 class="section-title">기술 스택</h2>
      
      <div class="skills-grid">
        <div class="skill-category">
          <h3><span class="skill-icon" aria-hidden="true">🧠</span> Frontend</h3>
          <div class="skill-icons-grid">
            <img src="https://skillicons.dev/icons?i=react,vue,ts,astro,tailwind" alt="Frontend Skills" />
          </div>
        </div>
        
        <div class="skill-category">
          <h3><span class="skill-icon" aria-hidden="true">⚡</span> Backend</h3>
          <div class="skill-icons-grid">
            <img src="https://skillicons.dev/icons?i=nodejs,python,postgres,mongodb,graphql" alt="Backend Skills" />
          </div>
        </div>
        
        <div class="skill-category">
          <h3><span class="skill-icon" aria-hidden="true">🔗</span> DevOps & Tools</h3>
          <div class="skill-icons-grid">
            <img src="https://skillicons.dev/icons?i=docker,aws,git,github,vercel" alt="DevOps Skills" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="featured-projects-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">주요 프로젝트</h2>
          <a href="/projects" class="view-all-link">전체 보기 →</a>
        </div>
        
        <div class="projects-grid">
          {featuredProjects.map((project: CollectionEntry<'projects'>, index: number) => (
            <article class="project-card" style={`animation-delay: ${index * 0.1}s`} data-fade-up>
              <div class="project-image">
                {(project.data.tags.includes('AI') || project.data.tags.includes('Machine Learning')) && (
                  <span class="ai-badge">🤖 AI Project</span>
                )}
                <img src={project.data.image.src} alt={project.data.title} loading="lazy" />
              </div>
              <div class="project-content">
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="project-tags">
                  {project.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Client Portfolio Preview -->
  {clientProjects.length > 0 && (
    <section class="client-preview-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">클라이언트 포트폴리오 (외주)</h2>
          <a href="/projects" class="view-all-link">전체 보기 →</a>
        </div>

        <div class="projects-grid">
          {clientProjects.map((project: CollectionEntry<'projects'>, index: number) => (
            <article class="project-card client-project-card" style={`animation-delay: ${index * 0.1}s`} data-fade-up>
              <div class={`project-image ${project.data.demo ? 'project-image-iframe' : ''}`}>
                {(project.data.tags.includes('AI') || project.data.tags.includes('Machine Learning')) && (
                  <span class="ai-badge">🤖 AI Project</span>
                )}
                {project.data.demo ? (
                  <iframe
                    src={project.data.demo}
                    title={`${project.data.title} 미리보기`}
                    loading="lazy"
                    class="project-preview-frame"
                  />
                ) : (
                  <img src={project.data.image.src} alt={project.data.title} loading="lazy" />
                )}
              </div>
              <div class="project-content">
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="project-tags">
                  {project.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>함께 일하고 싶으신가요?</h2>
        <p>새로운 프로젝트나 협업 기회에 항상 열려있습니다.</p>
        <a href="/about#contact" class="btn btn-primary">연락하기</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section — single-column centered layout */
  .hero {
    position: relative;
    padding: var(--spacing-2xl) 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Mobile fallback: static gradient when canvas is hidden */
  @media (max-width: 767px) {
    .hero {
      background: linear-gradient(
        135deg,
        rgba(6, 182, 212, 0.08),
        rgba(59, 130, 246, 0.06),
        rgba(139, 92, 246, 0.04),
        rgba(236, 72, 153, 0.02)
      );
    }
  }

  .hero .container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-content {
    z-index: 1;
    max-width: 720px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--spacing-md);
    line-height: 1.1;
  }

  /* AI_Gradient text fill on the name */
  .gradient-text {
    background: linear-gradient(135deg, var(--color-ai-cyan), var(--color-ai-blue), var(--color-ai-purple), var(--color-ai-magenta));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
    line-height: 1.8;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-accent);
    font-weight: 600;
    font-style: italic;
  }

  /* Typewriter */
  .typewriter-wrapper {
    margin-bottom: var(--spacing-lg);
    min-height: 2rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-ai-cyan);
  }

  .typewriter-text {
    background: linear-gradient(135deg, var(--color-ai-cyan), var(--color-ai-blue), var(--color-ai-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .typewriter-cursor {
    display: inline-block;
    color: var(--color-ai-cyan);
    animation: blink-cursor 1s step-end infinite;
    margin-left: 2px;
    font-weight: 300;
  }

  @keyframes blink-cursor {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Staggered fade-in: each element delays by index * 200ms */
  .hero-stagger {
    opacity: 0;
    animation: heroFadeIn 0.6s ease-out forwards;
    animation-delay: calc(var(--stagger-index, 0) * 200ms);
  }

  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* CTA buttons */
  .hero-cta {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-ai-cyan), var(--color-ai-purple));
    color: white;
    box-shadow: var(--shadow-md);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.4), 0 0 40px rgba(139, 92, 246, 0.2);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-ai-cyan);
    color: var(--color-ai-cyan);
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.3), 0 0 30px rgba(59, 130, 246, 0.15);
  }

  /* Skills Section */
  .skills-section {
    padding: var(--spacing-2xl) 0;
    background-color: var(--color-bg-secondary);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  /* Animated gradient border via @property */
  @property --gradient-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  .skill-category {
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: 2px solid transparent;
    background-origin: border-box;
    background-clip: padding-box, border-box;
    background-image:
      linear-gradient(var(--color-bg), var(--color-bg)),
      conic-gradient(from var(--gradient-angle), #06b6d4, #3b82f6, #8b5cf6, #ec4899, #06b6d4);
    animation: rotate-gradient 3s linear infinite;
    box-shadow: 0 0 8px 1px rgba(6, 182, 212, 0.15);
    transition: box-shadow var(--transition-base);
  }

  .skill-category:hover {
    box-shadow: 0 0 16px 4px rgba(6, 182, 212, 0.3), 0 0 30px 4px rgba(139, 92, 246, 0.15);
  }

  @keyframes rotate-gradient {
    to { --gradient-angle: 360deg; }
  }

  .skill-category h3 {
    margin-bottom: var(--spacing-md);
    color: var(--color-accent);
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .skill-icon {
    font-size: 1.25rem;
  }

  .skill-icons-grid {
    display: flex;
    justify-content: center;
  }

  .skill-icons-grid img {
    width: 100%;
    max-width: 300px;
  }

  /* CTA Section */
  .cta-section {
    padding: var(--spacing-2xl) 0;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.1));
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    margin-bottom: var(--spacing-md);
  }

  .cta-content p {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-lg);
  }

  /* Featured Projects */
  .featured-projects-section {
    padding: var(--spacing-2xl) 0;
  }

  .client-preview-section {
    padding: var(--spacing-xl) 0 var(--spacing-2xl);
    background: radial-gradient(circle at top left, rgba(56, 189, 248, 0.08), transparent 55%);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-xl);
  }

  .view-all-link {
    font-weight: 600;
    transition: transform var(--transition-fast);
  }

  .view-all-link:hover {
    transform: translateX(4px);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .project-card {
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: all var(--transition-base);
    opacity: 0;
    transform: translateY(30px);
  }

  .project-card.fade-up-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out, box-shadow var(--transition-base), border-color var(--transition-base);
  }

  [data-theme="dark"] .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.3), 0 0 40px rgba(139, 92, 246, 0.15);
    border-color: var(--color-ai-cyan);
  }

  [data-theme="dark"] .project-card.fade-up-visible:hover {
    transform: translateY(-8px);
  }

  :root .project-card:hover,
  :not([data-theme="dark"]) .project-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  :not([data-theme="dark"]) .project-card.fade-up-visible:hover {
    transform: translateY(-8px);
  }

  .client-project-card {
    border-color: rgba(56, 189, 248, 0.6);
  }

  .project-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background-color: var(--color-border);
  }

  .project-image-iframe {
    background-color: var(--color-bg);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-preview-frame {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .project-content {
    padding: var(--spacing-md);
  }

  .project-content h3 {
    margin-bottom: var(--spacing-sm);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin: var(--spacing-md) 0;
  }

  .tag {
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(139, 92, 246, 0.1));
    color: var(--color-text-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.9), rgba(139, 92, 246, 0.9));
    color: white;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(6, 182, 212, 0.4); }
    50% { box-shadow: 0 0 20px rgba(6, 182, 212, 0.7), 0 0 30px rgba(139, 92, 246, 0.3); }
  }

</style>

<script>
  import { initTypewriter } from '../scripts/typewriter';

  function setupIndexPage() {
    const el = document.getElementById('typewriter-text');
    if (el) {
      const tw = initTypewriter({
        element: el,
        phrases: ['Building with AI', 'Full-Stack Developer', 'Machine Learning Enthusiast'],
        typeSpeed: 50,
        deleteSpeed: 30,
        pauseDuration: 2000,
      });
      tw.start();
    }

    const fadeUpCards = document.querySelectorAll('[data-fade-up]');
    if (fadeUpCards.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('fade-up-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      fadeUpCards.forEach((card) => observer.observe(card));
    }
  }

  document.addEventListener('astro:page-load', setupIndexPage);
</script>
