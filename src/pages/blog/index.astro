---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const PAGE_SIZE = 5;
const allEntries = await getCollection('blog');
const totalPages = Math.max(1, Math.ceil(allEntries.length / PAGE_SIZE));
const currentPage = 1;
const entries = allEntries.slice(0, PAGE_SIZE);

// Helper to extract plain text from Notion rich text arrays
function richTextToPlainText(data: ReadonlyArray<{ plain_text: string }>): string {
  return data.map((text) => text.plain_text).join('');
}

// Helper to extract data from notion-astro-loader entries
function getPostData(entry: (typeof allEntries)[number]) {
  const props = entry.data.properties;
  const title = richTextToPlainText(props.Title?.title ?? []);
  const description = richTextToPlainText(props.Description?.rich_text ?? []);
  const publishedAt = props['Published Date']?.date?.start
    ? new Date(props['Published Date'].date.start)
    : new Date();
  const tags = props.Tags?.multi_select?.map((t: { name: string }) => t.name) ?? [];
  return { id: entry.id, title, description, publishedAt, tags };
}
---

<BaseLayout title="블로그 - Douglas" description="민동익(Douglas)의 개발과 기술에 대한 생각">
  <section class="page-header">
    <div class="container">
      <h1 class="animate-fade-in">블로그</h1>
      <p class="animate-fade-in">개발과 기술에 대한 생각을 공유합니다</p>
    </div>
  </section>

  <section class="blog-section">
    <div class="container">
      {entries.length === 0 ? (
        <div class="no-posts">
          <p>Notion에서 블로그 포스트를 설정하세요.<br />Published ✅ 체크박스를 활성화하면 여기에 표시됩니다! 🚀</p>
        </div>
      ) : (
        <div class="posts-grid">
          {entries.map((entry, index) => {
            const post = getPostData(entry);
            return (
            <article 
              class="post-card"
              style={`animation-delay: ${index * 0.1}s`}
            >
              <a href={`/blog/${post.id}`} class="post-link">
                <div class="post-number">{String(index + 1).padStart(2, '0')}</div>
                <div class="post-content">
                  <div class="post-header">
                    <time datetime={post.publishedAt.toISOString()} class="post-date">
                      {post.publishedAt.toLocaleDateString('ko-KR', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </time>
                  </div>
                  
                  <h2 class="post-title">{post.title}</h2>
                  <p class="post-description">{post.description}</p>
                  
                  <div class="post-footer">
                    <div class="post-tags">
                      {post.tags.slice(0, 3).map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                      {post.tags.length > 3 && (
                        <span class="tag-more">+{post.tags.length - 3}</span>
                      )}
                    </div>
                    
                    <span class="read-more">
                      Read more 
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            </article>
            );
          })}
        </div>
      )}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <a class:list={["page-link", { disabled: currentPage <= 1 }]} href={undefined}>
            이전
          </a>
          <div class="page-numbers">
            {Array.from({ length: totalPages }, (_, index) => {
              const pageNumber = index + 1;
              const href = pageNumber === 1 ? '/blog' : `/blog/page/${pageNumber}`;
              return (
                <a class:list={["page-number", { active: pageNumber === currentPage }]} href={href}>
                  {pageNumber}
                </a>
              );
            })}
          </div>
          <a class:list={["page-link", { disabled: currentPage >= totalPages }]} href={currentPage >= totalPages ? undefined : `/blog/page/${currentPage + 1}`}>
            다음
          </a>
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const LIST_URL_KEY = 'blogListUrl';
  const SCROLL_KEY = 'blogListScroll';
  const RESTORE_KEY = 'blogListRestore';

  function saveScroll() {
    sessionStorage.setItem(LIST_URL_KEY, window.location.pathname + window.location.search + window.location.hash);
    sessionStorage.setItem(SCROLL_KEY, String(window.scrollY));
  }

  window.addEventListener('scroll', saveScroll, { passive: true });
  saveScroll();

  if (sessionStorage.getItem(RESTORE_KEY) === '1') {
    const savedUrl = sessionStorage.getItem(LIST_URL_KEY);
    const savedScroll = Number(sessionStorage.getItem(SCROLL_KEY) || 0);
    if (savedUrl === window.location.pathname + window.location.search + window.location.hash) {
      window.scrollTo({ top: savedScroll, behavior: 'instant' });
    }
    sessionStorage.removeItem(RESTORE_KEY);
  }
</script>

<style>
  .page-header {
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align: center;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: var(--spacing-md);
  }

  .page-header p {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
  }

  .blog-section {
    padding: var(--spacing-2xl) 0;
  }

  .no-posts {
    text-align: center;
    padding: var(--spacing-2xl);
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
  }

  .no-posts p {
    font-size: 1.125rem;
    margin: 0;
  }

  .posts-grid {
    display: grid;
    gap: var(--spacing-xl);
    max-width: 900px;
    margin: 0 auto;
  }

  .post-card {
    background-color: var(--color-bg);
    border: 2px solid transparent;
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
    position: relative;
  }

  .post-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-lg);
    padding: 2px;
    background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .post-card:hover::before {
    opacity: 1;
  }

  .post-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .post-link {
    display: flex;
    gap: var(--spacing-lg);
    color: inherit;
    padding: var(--spacing-lg);
    position: relative;
    z-index: 10; /* 링크를 최상위로! */
    text-decoration: none;
  }

  .post-number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-border);
    line-height: 1;
    font-family: var(--font-mono);
    flex-shrink: 0;
    width: 80px;
    transition: all var(--transition-base);
  }

  .post-card:hover .post-number {
    background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transform: scale(1.1);
  }

  .post-content {
    flex: 1;
  }

  .post-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .read-time {
    font-size: 0.875rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-title {
    font-size: 1.75rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
    line-height: 1.3;
  }

  .post-description {
    margin-bottom: var(--spacing-md);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .post-card:hover .tag {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .tag-more {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .read-more {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: all var(--transition-fast);
  }

  .post-card:hover .read-more {
    gap: 0.5rem;
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .post-card:hover .read-more svg {
    transform: translateX(4px);
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-2xl);
    flex-wrap: wrap;
  }

  .page-numbers {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .page-link,
  .page-number {
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    font-weight: 600;
    transition: all var(--transition-fast);
  }

  .page-number.active {
    background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
    color: white;
    border-color: transparent;
  }

  .page-link:hover,
  .page-number:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .page-link.disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .post-link {
      flex-direction: column;
    }

    .post-number {
      width: auto;
      font-size: 2rem;
    }
  }
</style>
